rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /snipeTargets/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /trades/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /trackedTokens/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /trackedWallets/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /signals/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /cexTrades/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

    }
  }
}
