# Copy this file to ".env" (same folder) and fill in your values.
# Run the bot with:  cd functions  ->  npm run bot

# --- Discord ---
DISCORD_BOT_TOKEN=your-bot-token
# Optional: a dedicated channel id where the bot replies to EVERY message.
# (Enable Developer Mode in Discord, right-click the channel -> Copy Channel ID.)
DISCORD_CHANNEL_ID=

# --- AI models (set the one(s) you use) ---
DEEPSEEK_API_KEY=your-deepseek-key
OPENAI_API_KEY=your-openai-key

# --- FXcrypt backend (needed only to EXECUTE approved trades) ---
# Same value as your Firebase BOT_SECRET. Get it with:
#   firebase functions:secrets:access BOT_SECRET
BOT_SECRET=your-bot-secret
# Optional, improves Solana trades + enables SOL token holder counts:
HELIUS_API_KEY=
# Optional, enables EVM (BSC/ETH) token holder counts in the tracker tool:
MORALIS_API_KEY=

# --- Firebase Admin credentials ---
# Path to a service account JSON (Firebase console -> Project settings ->
# Service accounts -> Generate new private key). Either set this path, or just
# save the file into discord-gateway/ (any filename) and leave this blank.
GOOGLE_APPLICATION_CREDENTIALS=
